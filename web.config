<?xml version="1.0" encoding="UTF-8"?>
<!-- IIS doesn't map the .md extension to a MIME type by default, and
     js/docs.js fetches docs/*.md directly in the browser. Without this,
     IIS returns 404.3 (MIME type not allowed) for every doc page. -->
<configuration>
  <system.webServer>
    <staticContent>
      <mimeMap fileExtension=".md" mimeType="text/markdown" />
    </staticContent>
    <!-- Without this, IIS serves its own generic error page instead of
         404.html for any unmatched URL. -->
    <httpErrors errorMode="Custom" existingResponse="Replace">
      <remove statusCode="404" subStatusCode="-1" />
      <error statusCode="404" path="/404.html" responseMode="ExecuteURL" />
    </httpErrors>
  </system.webServer>
</configuration>
